<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Instalador - Sistema PDV 3D</title>
    <meta http-equiv="x-ua-compatible" content="ie=11">
    <HTA:APPLICATION 
        ID="InstaladorPDV" 
        APPLICATIONNAME="InstaladorPDV" 
        BORDER="dialog" 
        INNERBORDER="no" 
        CAPTION="yes" 
        ICON="" 
        MAXIMIZEBUTTON="no" 
        MINIMIZEBUTTON="yes" 
        SHOWINTASKBAR="yes" 
        SINGLEINSTANCE="yes" 
        SYSMENU="yes" 
        WINDOWSTATE="normal" 
        SCROLL="no"
    />
    <style>
        body { font-family: 'Segoe UI', Tahoma, sans-serif; background-color: #f4f4f5; padding: 25px; margin: 0; color: #333; overflow: hidden; }
        .container { background-color: #fff; padding: 25px; border-radius: 10px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); width: 480px; margin: 0 auto; box-sizing: border-box; }
        h2 { margin-top: 0; color: #2563eb; font-size: 24px; text-align: center; }
        p { font-size: 14px; line-height: 1.5; color: #475569; text-align: center; margin-bottom: 25px; }
        .status-box { background-color: #f8fafc; border: 1px solid #cbd5e1; padding: 12px; margin-top: 20px; border-radius: 6px; font-size: 12px; height: 130px; overflow-y: auto; color: #334155; font-family: Consolas, monospace; }
        .btn { background-color: #2563eb; color: white; border: none; padding: 14px; border-radius: 6px; font-size: 15px; cursor: pointer; margin-top: 20px; width: 100%; font-weight: bold; transition: background-color 0.2s; }
        .btn:hover { background-color: #1d4ed8; }
        .btn:disabled { background-color: #94a3b8; cursor: not-allowed; }
        .checkbox-container { margin-top: 20px; font-size: 15px; display: flex; align-items: center; justify-content: center; }
        .checkbox-container input { margin-right: 10px; width: 16px; height: 16px; cursor: pointer; }
    </style>
    <script>
        window.onload = function() {
            window.resizeTo(560, 500);
            window.moveTo((screen.width - 560) / 2, (screen.height - 500) / 2);
        };

        function updateStatus(msg) {
            var el = document.getElementById("status");
            el.innerHTML += msg + "<br>";
            el.scrollTop = el.scrollHeight;
        }

        function startInstall() {
            document.getElementById("btnInstall").disabled = true;
            document.getElementById("btnInstall").innerHTML = "Instalando... Aguarde";
            updateStatus("Iniciando instalação...");
            setTimeout(stepCheckNode, 50);
        }

        var shell, fso, currentDir;

        function stepCheckNode() {
            try {
                shell = new ActiveXObject("WScript.Shell");
                fso = new ActiveXObject("Scripting.FileSystemObject");
                currentDir = fso.GetAbsolutePathName(".");

                updateStatus("Verificando Node.js no sistema...");
                var nodeCheck = shell.Run("cmd /c node -v", 0, true);
                if (nodeCheck !== 0) {
                    updateStatus("<span style='color:#eab308'>Node.js não encontrado. Baixando e instalando automaticamente (isso pode demorar alguns minutos)...</span>");
                    
                    var psScript = "Invoke-WebRequest -Uri 'https://nodejs.org/dist/v20.14.0/node-v20.14.0-x64.msi' -OutFile 'node_installer.msi'; Start-Process msiexec.exe -ArgumentList '/i node_installer.msi /quiet /norestart' -Wait; Remove-Item 'node_installer.msi' -ErrorAction SilentlyContinue";
                    var installCmd = "powershell -WindowStyle Hidden -Command \"" + psScript + "\"";
                    var installRes = shell.Run(installCmd, 0, true);
                    
                    if (installRes === 0) {
                        updateStatus("<span style='color:green'>Node.js instalado com sucesso!</span>");
                    } else {
                        updateStatus("<span style='color:red'>Falha ao instalar o Node.js. Verifique sua internet ou instale manualmente.</span>");
                        resetButton();
                        return;
                    }
                } else {
                    updateStatus("<span style='color:green'>Node.js verificado.</span>");
                }
                setTimeout(stepInstallNpm, 50);
            } catch (e) { handleError(e); }
        }

        function stepInstallNpm() {
            try {
                updateStatus("Baixando bibliotecas necessárias (Isso pode levar alguns minutos)...");
                setTimeout(function() {
                    var npmCheck = shell.Run("cmd /c npm install", 0, true);
                    if (npmCheck !== 0) {
                        npmCheck = shell.Run("cmd /c \"C:\\Program Files\\nodejs\\npm.cmd\" install", 0, true);
                    }

                    if (npmCheck !== 0) {
                        updateStatus("<span style='color:#eab308'>Aviso: As bibliotecas foram processadas com alguns alertas.</span>");
                    } else {
                        updateStatus("<span style='color:green'>Bibliotecas instaladas com sucesso.</span>");
                    }
                    setTimeout(stepConfigDB, 50);
                }, 50);
            } catch (e) { handleError(e); }
        }

        function stepConfigDB() {
            try {
                updateStatus("Configurando banco de dados...");
                if (!fso.FileExists(currentDir + "\\.env")) {
                    var envFile = fso.CreateTextFile(currentDir + "\\.env", true);
                    envFile.WriteLine('DATABASE_URL="file:../dev.db"');
                    envFile.Close();
                    updateStatus("Arquivo .env gerado.");
                }

                updateStatus("Sincronizando tabelas do sistema...");
                setTimeout(function() {
                    var npxPush = shell.Run("cmd /c npx prisma db push", 0, true);
                    if (npxPush !== 0) shell.Run("cmd /c \"C:\\Program Files\\nodejs\\npx.cmd\" prisma db push", 0, true);
                    
                    var npxGen = shell.Run("cmd /c npx prisma generate", 0, true);
                    if (npxGen !== 0) shell.Run("cmd /c \"C:\\Program Files\\nodejs\\npx.cmd\" prisma generate", 0, true);

                    updateStatus("<span style='color:green'>Banco de dados pronto para uso.</span>");
                    setTimeout(stepShortcut, 50);
                }, 50);
            } catch (e) { handleError(e); }
        }

        function stepShortcut() {
            try {
                if (document.getElementById("chkShortcut").checked) {
                    updateStatus("Criando atalho na Área de Trabalho...");
                    var desktop = shell.SpecialFolders("Desktop");
                    var link = shell.CreateShortcut(desktop + "\\Sistema PDV 3D.lnk");
                    link.TargetPath = currentDir + "\\Abrir PDV.vbs";
                    link.WorkingDirectory = currentDir;
                    link.Description = "Atalho para o Sistema PDV";
                    link.IconLocation = currentDir + "\\icone.ico";
                    link.Save();
                    updateStatus("<span style='color:green'>Atalho criado.</span>");
                }
                setTimeout(stepFinish, 50);
            } catch (e) { handleError(e); }
        }

        function stepFinish() {
            updateStatus("<br><strong>✅ Instalação Concluída!</strong>");
            shell.Popup("O sistema foi instalado e configurado perfeitamente no seu computador.\n\nVocê já pode usar o Sistema PDV normalmente.", 0, "Instalação Concluída", 64);
            
            var btn = document.getElementById("btnInstall");
            btn.innerHTML = "Fechar Instalador";
            btn.disabled = false;
            btn.onclick = function() { window.close(); };
        }

        function handleError(e) {
            updateStatus("<span style='color:red'>Erro inesperado: " + e.message + "</span>");
            resetButton();
        }

        function resetButton() {
            var btn = document.getElementById("btnInstall");
            btn.innerHTML = "Tentar Instalar Novamente";
            btn.disabled = false;
        }
    </script>
</head>
<body>
    <div class="container">
        <h2>Instalação do PDV 3D</h2>
        <p>Bem-vindo! Este assistente preparará o sistema para uso na sua máquina automaticamente.</p>
        
        <div class="checkbox-container">
            <input type="checkbox" id="chkShortcut" checked>
            <label for="chkShortcut">Adicionar atalho na Área de Trabalho</label>
        </div>

        <button id="btnInstall" class="btn" onclick="startInstall()">Instalar Sistema</button>

        <div id="status" class="status-box">
            Aguardando início da instalação...<br>
        </div>
    </div>
</body>
</html>
